---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { getPromoCodes, getStrapiMediaUrl, getPromoCodeBySlug, getPromoCodeByDocumentId } from '../../../lib/strapi';
import { markdownToHtml } from '../../../lib/markdown';
import type { PromoCode } from '../../../types/strapi';
import type { GetStaticPathsResult } from 'astro';

export const prerender = true;

export interface Props {
  lang: string;
  promo: PromoCode | null;
  localeSlugs: Record<string, string>;
}

const { lang, promo, localeSlugs } = Astro.props;

export async function getStaticPaths(): Promise<GetStaticPathsResult> {
  const locales = ['lv', 'en', 'ru'] as const;
  const paths: GetStaticPathsResult = [];

  for (const locale of locales) {
    const promoCodes = await getPromoCodes(locale, { active: true });

    for (const p of promoCodes) {
      // Build slug mapping by fetching the same document in all locales
      const localeSlugs: Record<string, string> = {
        [locale]: p.slug,
      };

      // Fetch slugs from other locales using documentId
      for (const otherLocale of locales) {
        if (otherLocale !== locale) {
          const otherPromo = await getPromoCodeByDocumentId(p.documentId, otherLocale);
          if (otherPromo) {
            localeSlugs[otherLocale] = otherPromo.slug;
          }
        }
      }

      paths.push({
        params: { lang: locale, slug: p.slug },
        props: {
          lang: locale,
          promo: p,
          localeSlugs,
        },
      });
    }
  }

  return paths;
}

const notFoundLabels: Record<string, string> = {
  lv: 'Akcijas kods nav atrasts',
  en: 'Promo code not found',
  ru: 'Промокод не найден',
};

const backLabels: Record<string, string> = {
  lv: 'Atpakaļ uz akciju kodiem',
  en: 'Back to promo codes',
  ru: 'Назад к промокодам',
};

const breadcrumbLabels: Record<string, string> = {
  lv: 'Akcijas kodi',
  en: 'Promo Codes',
  ru: 'Промокоды',
};

const copyLabels: Record<string, string> = {
  lv: 'Kopēt',
  en: 'Copy',
  ru: 'Копировать',
};

const visitLabels: Record<string, string> = {
  lv: 'Apmeklēt',
  en: 'Visit',
  ru: 'Посетить',
};

const expiryLabels: Record<string, string> = {
  lv: 'Spēkā līdz:',
  en: 'Valid until:',
  ru: 'Действует до:',
};

const termsLabels: Record<string, string> = {
  lv: 'Nosacījumi',
  en: 'Terms & Conditions',
  ru: 'Условия и положения',
};

const aboutBrandLabels: Record<string, string> = {
  lv: 'Par zīmolu',
  en: 'About the brand',
  ru: 'О бренде',
};

function formatExpiryDate(dateString: string | null, locale: string): string {
  if (!dateString) return "";
  const date = new Date(dateString);
  return date.toLocaleDateString(
    locale === "lv" ? "lv-LV" : locale === "ru" ? "ru-RU" : "en-US",
    {
      year: "numeric",
      month: "long",
      day: "numeric",
    },
  );
}

// Pre-render markdown description
const htmlDescription = promo?.description ? await markdownToHtml(promo.description) : null;
---

<Layout
  title={promo?.seoMetaTitle || promo?.title || notFoundLabels[lang]}
  description={promo?.seoMetaDescription || promo?.description || undefined}
  lang={lang}
  localeSlugs={localeSlugs}
  documentId={promo?.documentId}
  contentType="promo-codes"
>
  {promo ? (
    <div class="py-2 max-w-4xl mx-auto pb-12">
      <!-- Breadcrumbs -->
      <Breadcrumbs
        lang={lang}
        items={[
          { label: breadcrumbLabels[lang], href: `/${lang}/promo-codes` },
          { label: promo.title, href: undefined }
        ]}
      />

      <!-- Main promo code card - Redesigned -->
      <div class="bg-white rounded-xl shadow-md border border-gray-100 p-6 md:p-8 mb-8 mt-6">
        <div class="flex flex-col md:flex-row gap-8">
          <!-- Logo section with better styling -->
          <div class="flex-shrink-0">
            <div class="bg-gradient-to-br from-blue-50 to-purple-50 rounded-xl p-4 border border-gray-100">
              {promo?.logo ? (
                <img
                  src={getStrapiMediaUrl(promo?.logo)}
                  alt={promo?.brand?.name || "Brand logo"}
                  class="w-24 h-24 object-contain"
                  loading="lazy"
                />
              ) : (
                <div class="w-24 h-24 bg-white rounded-lg flex items-center justify-center border border-gray-200">
                  <span class="text-gray-400 text-3xl font-bold">
                    {promo.brand?.name?.[0]?.toUpperCase() || "?"}
                  </span>
                </div>
              )}
            </div>
          </div>

          <!-- Content section -->
          <div class="flex-1">
            <!-- Brand badge -->
            {promo.brand?.name && (
              <span class="inline-block px-3 py-1 bg-blue-50 text-blue-700 text-sm font-semibold rounded-full mb-3 border border-blue-100">
                {promo.brand.name}
              </span>
            )}
            
            <h1 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">{promo.title}</h1>

            <!-- Promo code display - Enhanced -->
            {promo.code && (
              <div class="bg-gradient-to-r from-gray-50 to-gray-100 rounded-xl p-5 mb-6 border border-gray-200">
                <div class="flex items-center gap-3">
                  <code class="flex-1 text-2xl md:text-3xl font-mono font-bold text-blue-600 tracking-wide">
                    {promo.code}
                  </code>
                  <button
                    type="button"
                    onclick={`navigator.clipboard.writeText('${promo.code}').then(() => alert('${copyLabels[lang]}: ${promo.code}'));`}
                    class="px-5 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-all text-sm font-semibold whitespace-nowrap shadow-sm hover:shadow-md"
                  >
                    <svg class="w-4 h-4 inline mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                    </svg>
                    {copyLabels[lang]}
                  </button>
                </div>
              </div>
            )}

            <!-- Description -->
            {htmlDescription && (
              <div
                class="text-gray-600 mb-6 prose prose-sm max-w-none [&>ol]:list-decimal [&>ol]:pl-6 [&>ol>li]:mb-1 [&>ul]:list-disc [&>ul]:pl-6 [&>ul>li]:mb-1"
                set:html={htmlDescription}
              />
            )}

            <!-- Info badges -->
            <div class="flex flex-wrap gap-3 mb-6">
              {promo.category && (
                <span class="inline-flex items-center gap-1.5 text-sm text-gray-600">
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                  </svg>
                  {promo.category.name}
                </span>
              )}
              {promo.expiryDate && (
                <span class="inline-flex items-center gap-1.5 text-sm text-gray-600">
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  {expiryLabels[lang]} {formatExpiryDate(promo.expiryDate, lang)}
                </span>
              )}
            </div>

            <!-- Action button -->
            {promo.affiliateLink && (
              <a
                href={promo.affiliateLink}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-8 py-3.5 bg-gradient-to-r from-blue-600 to-purple-600 text-white rounded-lg hover:from-blue-700 hover:to-purple-700 transition-all font-semibold shadow-md hover:shadow-lg"
              >
                {visitLabels[lang]}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            )}
          </div>
        </div>
      </div>

      <!-- Brand description section -->
      {promo.brand?.description && (
        <div class="bg-gray-50 rounded-xl border border-gray-100 p-6 md:p-8">
          <h2 class="text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {aboutBrandLabels[lang]}
          </h2>
          <p class="text-gray-600 leading-relaxed">{promo.brand.description}</p>
        </div>
      )}
    </div>
  ) : (
    <div class="text-center py-12 max-w-2xl mx-auto">
      <h1 class="text-2xl font-bold text-gray-900 mb-4">{notFoundLabels[lang]}</h1>
      <a href={`/${lang}/promo-codes`} class="text-blue-600 hover:underline">
        {backLabels[lang]}
      </a>
    </div>
  )}
</Layout>
